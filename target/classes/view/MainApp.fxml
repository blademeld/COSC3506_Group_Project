<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root" prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.MainAppController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <center>
      <VBox alignment="CENTER" spacing="12.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="PeerLink Chat" />
            <Label fx:id="subtitleLabel" text="Web3-based P2P Chat Application" />
            <TextField fx:id="ipField" maxWidth="250.0" promptText="Host IP address (Connect only)" />
            <TextField fx:id="portField" maxWidth="250.0" promptText="Port number" />
            <Button fx:id="hostButton" onAction="#handleHost" text="Host Session" />
            <Button fx:id="connectButton" onAction="#handleConnect" text="Connect to Peer" />
            <Label fx:id="errorLabel" style="-fx-text-fill: red;" />
         </children>
      </VBox>
   </center>
   <bottom>
      <Label fx:id="footerLabel" style="-fx-font-size: 14px; -fx-text-fill: gray;" text="COSC3506 - Course Project (Group 3)" BorderPane.alignment="CENTER" />
   </bottom>
</BorderPane>